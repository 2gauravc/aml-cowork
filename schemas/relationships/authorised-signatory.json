{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "authorised_signatory.schema",
  "title": "Authorised Signatory Relationship Schema",
  "description": "Relationship schema representing an individual authorised to sign for a company.",
  "type": "object",
  "properties": {
    "target_company_id": {
      "type": "string",
      "description": "company_id of the company for which the individual is authorised to sign."
    },
    "individual_id": {
      "type": "string",
      "description": "Identifier of the individual authorised as signatory."
    },
    "authority_type": {
      "type": "string",
      "enum": ["SOLE_SIGNATORY", "JOINT_SIGNATORY", "LIMITED_SIGNATORY", "BANK_ACCOUNT_SIGNATORY", "DOCUMENT_SIGNATORY", "OTHER"]
    },
    "authorisation_basis": {
      "type": "string",
      "enum": ["BOARD_RESOLUTION", "POWER_OF_ATTORNEY", "EMPLOYMENT_ROLE", "CONSTITUTIONAL_DOCUMENT", "OTHER"]
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": ["target_company_id", "individual_id", "authority_type", "authorisation_basis"]
}
