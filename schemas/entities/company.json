{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "company.schema",
  "title": "Company Schema",
  "description": "Reusable company entity schema used across KYC documents and cases.",
  "type": "object",
 
  "properties": {
    "company_id": {
      "type": "string",
      "pattern": "^CMP[0-9]{3}$",
      "description": "Internal bank-generated company identifier used for matching and relationships. Not document-visible."
    },
    "business_registration_number": {
      "type": "string",
      "description": "External business registration number for the company. This may appear on company registration evidence and generated documents."
    },
    "legal_name": {
      "type": "string"
    },
    "legal_form": {
      "$ref": "../primitives/company_legal_form.json" },  
    "incorporation_date": {
      "type": "string",
      "format": "date"
    },
    "incorporation_country": {
      "$ref": "../primitives/country.json"
    },
    "registered_address": {
      "type": "string",
      "pattern": "^ADD[0-9]{3}$",
      "description": "Address ID referencing an address entity."
    },
    "business_activity": {
      "type": "string"
    },
    "paid_up_capital": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "$ref": "../primitives/currency.json"
        }
      },
      "required": [
        "amount",
        "currency"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "INACTIVE", "DISSOLVED", "IN_LIQUIDATION", "STRUCK_OFF", "SUSPENDED", "UNDER_ADMINISTRATION", "OTHER"]
    }
  },

  "required": [
    "company_id",
    "business_registration_number",
    "legal_name",
    "incorporation_date",
    "incorporation_country",
    "registered_address"
  ]
}
