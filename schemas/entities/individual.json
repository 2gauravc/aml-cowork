{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "individual.schema",
  "title": "Individual Schema",
  "description": "Reusable individual entity schema used across KYC documents and cases.",
  "type": "object",

  "properties": {
    "individual_id": {
      "type": "string",
      "description": "System generated unique identifier for the individual."
    },
    "full_name": {
      "type": "string"
    },
    "date_of_birth": {
      "type": "string",
      "format": "date"
    },
    "nationality": {
      "$ref": "../primitives/country.schema.json"
    },
    "residential_address": {
      "$ref": "address.json"
    }
  },

  "required": [
    "individual_id",
    "full_name",
    "date_of_birth",
    "nationality"
  ]
}
