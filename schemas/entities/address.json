{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "address.schema",
  "title": "Address Schema",
  "description": "Reusable address schema used across KYC entities and documents.",
  "type": "object",

  "properties": {
    "address_line_1": {
      "type": "string"
    },
    "address_line_2": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state_province": {
      "type": "string"
    },
    "postal_code": {
      "type": "string"
    },
    "country": {
      "$ref": "../primitives/country.json"
    }
  },

  "required": [
    "address_line_1",
    "city",
    "country"
  ]
}